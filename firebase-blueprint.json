{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An organic dry fruit or lucky stone product.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Category (dry-fruits, lucky-stones)" },
        "image": { "type": "string", "description": "URL to product image" },
        "rating": { "type": "number", "description": "Average rating" },
        "reviewsCount": { "type": "integer", "description": "Number of reviews" },
        "stock": { "type": "integer", "description": "Current inventory count" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who placed the order" },
        "items": { "type": "array", "description": "List of cart items" },
        "total": { "type": "number", "description": "Total amount paid" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review from a user.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific product"
    }
  }
}
